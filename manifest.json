{
	"manifest_version": 3,
	"name": "Innertube Proxy",
	"version": "1.0.0",
	"description": "Proxies YouTube Innertube requests to innertube_proxy_server.",
	"icons": {
		"48": "images/icon-48.png",
		"128": "images/icon-128.png"
	},
	"permissions": [],
	"host_permissions": [
		"*://*.youtube.com/*",
		"http://localhost:53417/*"
	],
	"background": {
		"scripts": [
			"browser-polyfill.min.js",
			"background.js"
		]
	},
	"content_scripts": [
		{
			"matches": ["*://*.youtube.com/*"],
			"js": ["browser-polyfill.min.js", "content-script.js"],
			"all_frames": true,
			"run_at": "document_start"
		},
		{
			"matches": ["*://*.youtube.com/*"],
			"js": ["hijack-fetch.js"],
			"all_frames": true,
			"world": "MAIN",
			"run_at": "document_start"
		}
	]
}
