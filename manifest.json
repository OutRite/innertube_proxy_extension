{
	"manifest_version": 3,
	"name": "Innertube Proxy",
	"version": "1.1.0",
	"description": "Proxies YouTube Innertube requests to innertube_proxy_server.",
	"icons": {
		"48": "images/icon-48.png",
		"128": "images/icon-128.png"
	},
	"permissions": ["cookies", "storage"],
	"host_permissions": [
		"*://*.youtube.com/*",
		"*://*/*"
	],
	"background": {
		"service_worker": "background.js",
		"scripts": ["background.js"]
	},
	"options_ui": {
		"page": "options.html",
		"open_in_tab": false
	},
	"content_scripts": [
		{
			"matches": ["*://*.youtube.com/*"],
			"js": ["browser-polyfill.min.js", "content-script.js"],
			"all_frames": true,
			"run_at": "document_start"
		},
		{
			"matches": ["*://*.youtube.com/*"],
			"js": ["hijack-fetch.js"],
			"all_frames": true,
			"world": "MAIN",
			"run_at": "document_start"
		}
	],
	"browser_specific_settings": {
		"gecko": {
			"id": "innertube_proxy_extension@534"
		}
	}
}
